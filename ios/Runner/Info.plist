<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>CalyMob</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>calymob</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!-- Camera Permission (profile photo, expense receipts) -->
	<key>NSCameraUsageDescription</key>
	<string>CalyMob a besoin d'accéder à l'appareil photo pour prendre votre photo de profil et photographier vos justificatifs de dépenses.</string>
	<!-- Photo Library Permission (profile photo, expense receipts) -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>CalyMob a besoin d'accéder à votre photothèque pour importer une photo de profil ou un justificatif de dépense.</string>
	<!-- Photo Library Add Permission (saving cropped profile photo if needed) -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>CalyMob a besoin d'enregistrer des images dans votre photothèque (par exemple votre photo de profil recadrée).</string>
	<!-- Microphone / speech recognition for dictated logbook entries -->
	<key>NSMicrophoneUsageDescription</key>
	<string>CalyMob utilise le micro pour dicter une plongée dans votre carnet.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>CalyMob utilise la reconnaissance vocale pour transformer votre dictée en champs de plongée.</string>
	<!-- Push Notifications -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>
	<!-- Firebase Configuration -->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<true/>
	<!-- Face ID / Biometric Authentication -->
	<key>NSFaceIDUsageDescription</key>
	<string>CalyMob uses Face ID for secure and fast login.</string>
	<!-- Export Compliance - App uses only standard iOS encryption (HTTPS, Keychain) -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- Deep linking for payment return URLs -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.calypso.calymob</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>calymob</string>
			</array>
		</dict>
	</array>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>waze</string>
	</array>
</dict>
</plist>
