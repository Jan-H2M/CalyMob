rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasClubClaim(clubId) {
      return isAuthenticated() &&
        ('clubId' in request.auth.token) &&
        request.auth.token.clubId == clubId;
    }

    function hasValidAdminSessionForClubId(clubId) {
      return isAuthenticated()
        && clubId is string
        && isAdmin(clubId)
        && hasValidSession(clubId);
    }

    function tokenAppRole() {
      return ('app_role' in request.auth.token)
        ? request.auth.token.app_role
        : (('role' in request.auth.token) ? request.auth.token.role : '');
    }

    // Check if user is a member of the club (minimum access bar)
    // This is the baseline check for club-scoped data — ensures the user
    // is not just any Firebase Auth user, but actually a member of THIS club
    function isMember(clubId) {
      return isAuthenticated() &&
        (
          exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)) ||
          hasClubClaim(clubId)
        );
    }

    // Get user data from club-specific members collection
    function getUserData(clubId) {
      return get(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)).data;
    }

    // Check if user has admin or superadmin role for a specific club
    function isAdmin(clubId) {
      return isAuthenticated() && (
        (
          exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)) &&
          getUserData(clubId).app_role in ['admin', 'superadmin']
        ) ||
        (hasClubClaim(clubId) && tokenAppRole() in ['admin', 'superadmin'])
      );
    }

    // Check if user is superadmin for a specific club
    function isSuperAdmin(clubId) {
      return isAuthenticated() && (
        (
          exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)) &&
          getUserData(clubId).app_role == 'superadmin'
        ) ||
        (hasClubClaim(clubId) && tokenAppRole() == 'superadmin')
      );
    }

    // Encadrants, piscine-editors, and admins can manage piscine planning,
    // session themes, session plannings and attendee reassignments.
    // Accepts both the E-badge (Encadrant) and the P-badge (Piscine).
    function isPiscineFormationEditor(clubId) {
      let userData = getUserData(clubId);
      return isAdmin(clubId) || (
        isMember(clubId) &&
        ('clubStatuten' in userData) &&
        userData.clubStatuten.hasAny([
          'encadrant', 'Encadrant', 'encadrants', 'Encadrants', 'E',
          'piscine', 'Piscine', 'P'
        ])
      );
    }

    // Encadrants (E-badge) and admins can validate LIFRAS exercises,
    // build palanquées, and record member observations on dive operations.
    function isEncadrantForClub(clubId) {
      let userData = getUserData(clubId);
      return isAdmin(clubId) || (
        isMember(clubId) &&
        ('clubStatuten' in userData) &&
        userData.clubStatuten.hasAny(['encadrant', 'Encadrant', 'encadrants', 'Encadrants', 'E'])
      );
    }

    function hasCARole(clubId) {
      let userData = getUserData(clubId);
      return isAdmin(clubId) || (
        isMember(clubId) &&
        ('clubStatuten' in userData) &&
        userData.clubStatuten.hasAny(['ca', 'CA', 'comite', 'Comite', 'comité', 'Comité'])
      );
    }

    function hasClubStatut(clubId, statuten) {
      let userData = getUserData(clubId);
      return isMember(clubId)
        && ('clubStatuten' in userData)
        && userData.clubStatuten.hasAny(statuten);
    }

    function hasAccueilRole(clubId) {
      return hasClubStatut(clubId, ['accueil', 'Accueil', 'A']);
    }

    function hasGonflageRole(clubId) {
      return hasClubStatut(clubId, ['gonflage', 'Gonflage', 'G']);
    }

    function hasBureauRole(clubId) {
      return hasClubStatut(clubId, [
        'BS', 'bs', 'Banque Signature', 'banque signature',
        'bureau', 'Bureau', 'tresorier', 'trésorier', 'secretaire', 'secrétaire'
      ]);
    }

    function canAccessTeamChannel(clubId, channelId) {
      return isAdmin(clubId) || (
        isMember(clubId) && (
          channelId == 'general' ||
          (channelId == 'equipe_ca' && hasCARole(clubId)) ||
          (channelId == 'equipe_accueil' && hasAccueilRole(clubId)) ||
          (channelId == 'equipe_encadrants' && isEncadrantForClub(clubId)) ||
          (channelId == 'equipe_gonflage' && hasGonflageRole(clubId)) ||
          (channelId == 'bureau' && (hasBureauRole(clubId) || hasCARole(clubId))) ||
          (channelId == 'formation_1_etoile' && hasFormationTarget(clubId, '1*')) ||
          (channelId == 'formation_2_etoiles' && hasFormationTarget(clubId, '2*')) ||
          (channelId == 'formation_3_etoiles' && hasFormationTarget(clubId, '3*')) ||
          (channelId == 'formation_4_etoiles' && hasFormationTarget(clubId, '4*')) ||
          (channelId == 'formation_AM' && hasFormationTarget(clubId, 'AM'))
        )
      );
    }

    function hasFormationTarget(clubId, targetLevel) {
      return ('formation_active' in getUserData(clubId))
        && getUserData(clubId).formation_active == true
        && targetFormationLevel(clubId) == targetLevel;
    }

    function targetFormationLevel(clubId) {
      return ('target_formation_level' in getUserData(clubId) && getUserData(clubId).target_formation_level in ['1*', '1', 'P1']) ? '1*'
        : ('target_formation_level' in getUserData(clubId) && getUserData(clubId).target_formation_level in ['2*', '2', 'P2']) ? '2*'
        : ('target_formation_level' in getUserData(clubId) && getUserData(clubId).target_formation_level in ['3*', '3', 'P3']) ? '3*'
        : ('target_formation_level' in getUserData(clubId) && getUserData(clubId).target_formation_level in ['4*', '4', 'P4']) ? '4*'
        : ('target_formation_level' in getUserData(clubId) && getUserData(clubId).target_formation_level == 'AM') ? 'AM'
        : ('plongeur_code' in getUserData(clubId) && getUserData(clubId).plongeur_code in ['NB']) ? '1*'
        : ('plongeur_code' in getUserData(clubId) && getUserData(clubId).plongeur_code in ['P1', '1', '1*']) ? '2*'
        : ('plongeur_code' in getUserData(clubId) && getUserData(clubId).plongeur_code in ['P2', '2', '2*']) ? '3*'
        : ('plongeur_code' in getUserData(clubId) && getUserData(clubId).plongeur_code in ['P3', '3', '3*']) ? '4*'
        : ('plongeur_code' in getUserData(clubId) && getUserData(clubId).plongeur_code in ['P4', '4', '4*']) ? 'AM'
        : null;
    }

    function teamChannelTypeMatches(channelId, type) {
      return (channelId == 'general' && type == 'general')
        || (channelId == 'equipe_ca' && type == 'ca')
        || (channelId == 'equipe_accueil' && type == 'accueil')
        || (channelId == 'equipe_encadrants' && type == 'encadrants')
        || (channelId == 'equipe_gonflage' && type == 'gonflage')
        || (channelId == 'bureau' && type == 'bureau')
        || (channelId == 'formation_1_etoile' && type == 'formation_1_etoile')
        || (channelId == 'formation_2_etoiles' && type == 'formation_2_etoiles')
        || (channelId == 'formation_3_etoiles' && type == 'formation_3_etoiles')
        || (channelId == 'formation_4_etoiles' && type == 'formation_4_etoiles')
        || (channelId == 'formation_AM' && type == 'formation_AM');
    }

    function canManageExpenses(clubId) {
      let userData = getUserData(clubId);
      return isAdmin(clubId) || hasCARole(clubId) || (
        isMember(clubId) &&
        userData.app_role == 'validateur'
      );
    }

    // Organisateurs (O-badge) and admins can manage event logistics —
    // palanquée assignments and attendance records — for events they organize.
    // Separate from encadrant status (which is tariff/pedagogical only).
    function isOrganisateurForClub(clubId) {
      let userData = getUserData(clubId);
      return isAdmin(clubId) || (
        isMember(clubId) &&
        ('clubStatuten' in userData) &&
        userData.clubStatuten.hasAny(['organisateur', 'Organisateur', 'ORGANISATEUR', 'o', 'O'])
      );
    }

    // LIFRAS Moniteur — plongeur_code in MC / MF / MN. AM (Assistant Moniteur)
    // is bewust uitgesloten: per LIFRAS valideert AM enkel onder supervisie
    // van een MC+, en die supervisor-flow is nog niet gemodelleerd in de app.
    // Gebruikt door canValidateLifras() — zie volgende helper.
    function isMoniteurForClub(clubId) {
      let userData = getUserData(clubId);
      return isMember(clubId) &&
        ('plongeur_code' in userData) &&
        userData.plongeur_code in ['MC', 'MF', 'MN'];
    }

    // LIFRAS-validatie-gate — voor het valideren van oefeningen, examens en
    // het aanpassen van pedagogische thèmes/plannings. Vereist Encadrant-fonctie
    // EN Moniteur-niveau, of admin. Mirrors canValidateLifras() in fieldMapper.ts.
    function canValidateLifras(clubId) {
      return isAdmin(clubId) || (isEncadrantForClub(clubId) && isMoniteurForClub(clubId));
    }

    // Check if user has a valid session (timeout enforcement)
    // Simplified to avoid circular dependencies during login
    // NOTE: Returns true if session doesn't exist (for when autoLogoutEnabled is disabled)
    // SECURITY: Now also checks expiresAt timestamp to prevent expired session exploitation
    function hasValidSession(clubId) {
      let sessionPath = /databases/$(database)/documents/clubs/$(clubId)/sessions/$(request.auth.uid);
      // If session doesn't exist, allow access (auto-logout may be disabled)
      // If session exists, verify it's active AND not expired
      return !exists(sessionPath)
        || (
          get(sessionPath).data.isActive == true
          && get(sessionPath).data.expiresAt > request.time
        );
    }

    // Check if fiscal year data can be modified based on its status
    // Progressive locking: open (everyone) → closed (admins only) → permanently_closed (superadmin only)
    function canModifyFiscalYearData(clubId, fiscalYearId) {
      // Legacy data without fiscal_year_id: allow modification
      return fiscalYearId == null ||
        (
          exists(/databases/$(database)/documents/clubs/$(clubId)/fiscal_years/$(fiscalYearId)) &&
          (
            (get(/databases/$(database)/documents/clubs/$(clubId)/fiscal_years/$(fiscalYearId)).data.status == 'open') ||
            (get(/databases/$(database)/documents/clubs/$(clubId)/fiscal_years/$(fiscalYearId)).data.status == 'closed' && isAdmin(clubId)) ||
            (get(/databases/$(database)/documents/clubs/$(clubId)/fiscal_years/$(fiscalYearId)).data.status == 'permanently_closed' && isSuperAdmin(clubId))
          )
        );
    }

    // Calculate effective deadline for an operation's inscription period.
    // Uses the explicit registration_deadline if set on the operation,
    // otherwise falls back to date_debut - 24 hours.
    // Use .get('registration_deadline', null) instead of bare access:
    // the field is optional in the data model (legacy operations and
    // bulk-creators in OperationsPage.tsx don't set it). A bare
    // `opData.registration_deadline` access can trip the same rules-engine
    // missing-field denial we hit with the `categorie` regression.
    function effectiveDeadline(opData) {
      return opData.get('registration_deadline', null) != null
        ? opData.registration_deadline
        : opData.date_debut - duration.value(24, 'h');
    }

    // Check if user can view/modify a document based on role and ownership
    // USER ISOLATION: 'user' role can only access their own documents
    function canAccessDocument(clubId, ownerId) {
      let userData = getUserData(clubId);
      let userRole = userData.app_role;

      // Superadmin, admin, validateur can see everything
      // User role can only see their own documents
      return userRole in ['superadmin', 'admin', 'validateur'] ||
             (userRole == 'user' && request.auth.uid == ownerId);
    }

    function canAccessBoutique(clubId) {
      let userData = getUserData(clubId);
      let flags = get(/databases/$(database)/documents/clubs/$(clubId)/settings/feature_flags).data;

      return isMember(clubId)
        && (flags.boutiqueEnabled == true || flags.boutiqueMobileEnabled == true)
        && (
          userData.app_role in ['admin', 'superadmin'] ||
          (('feature_access' in userData) && userData.feature_access.boutique == true)
        );
    }

    // CRITICAL: Validate approval metadata when setting status to 'approuve' (legacy)
    // or 'approved' (canonical). Two separate functions so each rule only touches the
    // fields of its own schema — sharing one dual-language function caused permission
    // regressions when the absent-language field was accessed on a single-language doc.
    function hasValidApprovalMetadata(data) {
      // Legacy schema (demandes_remboursement)
      return data.statut != 'approuve' || (
        data.approuve_par != null &&
        data.approuve_par_nom != null &&
        data.date_approbation != null
      );
    }

    function hasCanonicalApprovalMetadata(data) {
      // Canonical schema (expense_claims) — see normalizeCanonicalExpenseClaimPayload()
      return data.status != 'approved' || (
        data.approved_by != null &&
        data.approved_by_name != null &&
        data.approved_at != null
      );
    }

    // For development/emulator - simplified rules for most data
    // Permission settings have strict protection

    // Clubs collection
    match /clubs/{clubId} {
      // Sessions subcollection - special rules for session management
      match /sessions/{sessionId} {
        // Users can only read/write their own session
        allow read: if isAuthenticated() && request.auth.uid == sessionId;
        allow create: if isAuthenticated() && request.auth.uid == sessionId;
        allow update: if isAuthenticated() && request.auth.uid == sessionId;
        allow delete: if isAuthenticated() && request.auth.uid == sessionId;
      }

      // Active sessions subcollection (alternative path used by SessionService)
      match /active_sessions/{sessionId} {
        // Users can only read/write their own session
        allow read: if isAuthenticated() && request.auth.uid == sessionId;
        allow create: if isAuthenticated() && request.auth.uid == sessionId;
        allow update: if isAuthenticated() && request.auth.uid == sessionId;
        allow delete: if isAuthenticated() && request.auth.uid == sessionId;
      }

      // Settings subcollection with special rules
      match /settings/{settingId} {
        // Security, permissions, and AI API keys - can be read without session (loaded during auth initialization)
        // - security: needed for session validation itself
        // - permissions: needed to determine user capabilities during auth
        // - ai_api_keys: loaded during auth context initialization
        // - compatibility: needed for browser/device compatibility checks during login
        // Other API Keys - RESTRICTED to admin/superadmin with valid session
        // automated_jobs - admin/superadmin only
        // Security, permissions, compatibility: needed during login (member check, no session)
        // AI API keys: admin only
        // Google Mail, email config, automated jobs: admin + session
        // Other settings (bilan_codes, app_version, etc.): member check required
        allow read: if settingId in ['security', 'permissions', 'ai_api_keys', 'compatibility']
          ? (settingId == 'security' || settingId == 'permissions' || settingId == 'compatibility' ? isMember(clubId) : isAdmin(clubId))
          : settingId in ['google_mail', 'email_config']
            ? (isAdmin(clubId) && hasValidSession(clubId))
            : settingId == 'automated_jobs'
              ? (isAdmin(clubId) && hasValidSession(clubId))
              : isMember(clubId);

        // Only admins can write, and they need a valid session
        allow write: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Email templates - admin management only
      match /email_templates/{templateId} {
        allow read: if isMember(clubId) && hasValidSession(clubId);
        allow write: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Branding presets - reusable email branding styles (LEGACY)
      match /brandings/{brandingId} {
        allow read: if isMember(clubId) && hasValidSession(clubId);
        allow write: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // ========== BRANDING LIBRARY (New architecture) ==========
      // Main branding library document
      match /branding/library {
        allow read: if isMember(clubId);
        allow write: if isAdmin(clubId) && hasValidSession(clubId);

        // Logos subcollection
        match /logos/{logoId} {
          allow read: if isMember(clubId);
          allow write: if isAdmin(clubId) && hasValidSession(clubId);
        }

        // Color palettes subcollection
        match /palettes/{paletteId} {
          allow read: if isMember(clubId);
          allow write: if isAdmin(clubId) && hasValidSession(clubId);
        }

        // Images/assets subcollection
        match /images/{imageId} {
          allow read: if isMember(clubId);
          allow write: if isAdmin(clubId) && hasValidSession(clubId);
        }

        // HTML templates subcollection
        match /templates/{templateId} {
          allow read: if isMember(clubId);
          allow write: if isAdmin(clubId) && hasValidSession(clubId);
        }
      }

      // Email history - track sent emails
      match /email_history/{historyId} {
        allow read: if isAuthenticated()
          && hasValidSession(clubId)
          && getUserData(clubId).app_role in ['superadmin', 'admin', 'validateur'];
        allow create, update, delete: if false;
      }

      // Communication entries - dossier-level communication timeline
      match /communication_entries/{entryId} {
        allow read: if isMember(clubId) && canManageExpenses(clubId);
        allow create: if isMember(clubId)
          && hasValidSession(clubId)
          && canManageExpenses(clubId);
        allow update: if isMember(clubId)
          && hasValidSession(clubId)
          && canManageExpenses(clubId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read_by']);
        allow delete: if false;
      }

      // Email drafts - saved email drafts for manual sending (admin only)
      match /email_drafts/{draftId} {
        allow read: if isAdmin(clubId) && hasValidSession(clubId);
        allow create, update: if isAdmin(clubId) && hasValidSession(clubId);
        allow delete: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Communication logs - read-only for admin/validateur
      match /communication_logs/{logId} {
        allow read: if isMember(clubId) && hasValidSession(clubId)
          && getUserData(clubId).app_role in ['superadmin', 'admin', 'validateur'];
        allow create: if false; // Only Cloud Functions can create logs
        allow update, delete: if false; // Logs are immutable
      }

      // Automated jobs logs - read-only for authenticated members
      match /automated_jobs_logs/{logId} {
        allow read: if isAuthenticated()
          && exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid));
        allow create: if false; // Only Cloud Functions/Vercel API can create logs
        allow update, delete: if false; // Logs are immutable
      }

      // Dive locations (event settings) - readable by members (mobile app), writable by admins
      match /dive_locations/{locationId} {
        allow read: if isMember(clubId);
        allow write: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // LIFRAS exercises - can be read by club members (mobile + web), written by admins only
      match /exercices_lifras/{exerciceId} {
        allow read: if isMember(clubId);
        allow write: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Categories - can be read by club members, written by admins only
      match /categories/{categoryId} {
        allow read: if isMember(clubId);
        allow write: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Categorization patterns (smart categorization learning)
      match /categorization_patterns/{patternId} {
        allow read: if isMember(clubId);
        allow create, update: if isMember(clubId) && hasValidSession(clubId);
        allow delete: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Anti-patterns (corrections tracking for categorization)
      match /anti_patterns/{patternId} {
        allow read: if isMember(clubId);
        allow create, update: if isMember(clubId) && hasValidSession(clubId);
        allow delete: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Known IBANs (pre-configured IBANs for auto-categorization)
      match /known_ibans/{ibanId} {
        allow read: if isMember(clubId);
        allow create, update: if isAdmin(clubId) && hasValidSession(clubId);
        allow delete: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Facturation - carnet de clients externes (admin only)
      match /facturation_clients/{clientId} {
        allow read: if isAdmin(clubId) && hasValidSession(clubId);
        allow create, update: if isAdmin(clubId) && hasValidSession(clubId);
        allow delete: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Facturation - factures sortantes (admin only)
      match /factures/{factureId} {
        allow read: if isAdmin(clubId) && hasValidSession(clubId);
        allow create, update: if isAdmin(clubId) && hasValidSession(clubId);
        allow delete: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // OGM / communications structurées - références de paiement.
      // Indexe un OGM -> contexte (facture, cotisation, boutique, remboursement)
      // pour la réconciliation bancaire automatique. Mêmes rôles que les
      // transactions bancaires (lecture + écriture par le moteur de matching).
      match /payment_references/{ogm} {
        allow read: if isAuthenticated()
          && getUserData(clubId).app_role in ['superadmin', 'admin', 'validateur'];
        allow create, update: if isAuthenticated()
          && hasValidSession(clubId)
          && getUserData(clubId).app_role in ['superadmin', 'admin', 'validateur'];
      }

      // Transactions bancaires - USER ISOLATION: only admin/validateur/superadmin
      match /transactions_bancaires/{transactionId} {
        // Read: Only validateur, admin, superadmin (user role has NO access)
        allow read: if isAuthenticated() && getUserData(clubId).app_role in ['superadmin', 'admin', 'validateur'];
        allow create, update: if isAuthenticated()
          && hasValidSession(clubId)
          && getUserData(clubId).app_role in ['superadmin', 'admin', 'validateur']
          && canModifyFiscalYearData(clubId, request.resource.data.get('fiscal_year_id', null));
        // Delete: Superadmin can delete any transaction
        // Admin can delete child transactions (splits) or non-reconciled transactions
        allow delete: if hasValidSession(clubId) && (
          isSuperAdmin(clubId) ||
          (
            isAdmin(clubId) &&
            canModifyFiscalYearData(clubId, resource.data.fiscal_year_id) &&
            (
              resource.data.parent_transaction_id != null ||
              resource.data.reconcilie == false ||
              !('reconcilie' in resource.data)
            )
          )
        );
      }

      // Bank transactions (English collection name) - USER ISOLATION: only admin/validateur/superadmin
      match /bank_transactions/{transactionId} {
        // Read: Only validateur, admin, superadmin (user role has NO access)
        allow read: if isAuthenticated() && getUserData(clubId).app_role in ['superadmin', 'admin', 'validateur'];
        allow create, update: if isAuthenticated()
          && hasValidSession(clubId)
          && getUserData(clubId).app_role in ['superadmin', 'admin', 'validateur']
          && canModifyFiscalYearData(clubId, request.resource.data.get('fiscal_year_id', null));
        // Delete: Superadmin can delete any transaction
        // Admin can delete child transactions (splits) or non-reconciled transactions
        allow delete: if hasValidSession(clubId) && (
          isSuperAdmin(clubId) ||
          (
            isAdmin(clubId) &&
            canModifyFiscalYearData(clubId, resource.data.fiscal_year_id) &&
            (
              resource.data.parent_transaction_id != null ||
              resource.data.reconcilie == false ||
              !('reconcilie' in resource.data)
            )
          )
        );
      }

      // Demandes de remboursement - USER ISOLATION: user can only see their own
      match /demandes_remboursement/{claimId} {
        // Read: User role can only see their own demands (via demandeur_id)
        allow read: if isMember(clubId) && (
          canManageExpenses(clubId) ||
          (getUserData(clubId).app_role == 'user' && resource.data.demandeur_id == request.auth.uid)
        );

        // Create: Club members can create their own demands — EXCEPT for
        // 'remboursement_inscription' which is reserved for the callable
        // Cloud Function (createInscriptionRefund) that validates the
        // actual price delta matches a real inscription change.
        // NOTE: use .get('categorie', '') because most client payloads
        // (TransactionsPage, DemandesPage.handleNewExpense) don't set the
        // field at all; a bare `data.categorie != ...` on a missing field
        // denies the write instead of coercing to null.
        allow create: if isMember(clubId)
          && request.resource.data.get('categorie', '') != 'remboursement_inscription'
          && (
            canManageExpenses(clubId) ||
            request.resource.data.demandeur_id == request.auth.uid
          );

        // Update: User can update their own demands (if not yet approved), admin+ can update all
        // CRITICAL: Validate approval metadata when status is set to 'approuve'
        allow update: if isMember(clubId)
          && hasValidApprovalMetadata(request.resource.data)
          && (
            canManageExpenses(clubId) ||
            (
              getUserData(clubId).app_role == 'user' &&
              resource.data.demandeur_id == request.auth.uid &&
              resource.data.statut in ['brouillon', 'soumis']
            )
          );

        // Delete: Admin only
        allow delete: if isAdmin(clubId)
          && hasValidSession(clubId)
          && canModifyFiscalYearData(clubId, resource.data.fiscal_year_id);
      }

      // Expense claims (canonical English collection) - mirrors demandes_remboursement
      // CANONICAL FIELDS: requester_id (not demandeur_id), status (not statut),
      // approved_by/approved_by_name/approved_at (not approuve_par/...).
      // See normalizeCanonicalExpenseClaimPayload() in expenseClaimGateway.ts for full mapping.
      match /expense_claims/{claimId} {
        // Read: User role can only see their own claims (via canonical requester_id)
        allow read: if isMember(clubId) && (
          canManageExpenses(clubId) ||
          (getUserData(clubId).app_role == 'user' && resource.data.requester_id == request.auth.uid)
        );

        // Create: User can create own claims; admin/validateur can mirror-create on
        // behalf of any requester. 'remboursement_inscription' is reserved for
        // the callable Cloud Function and cannot be created directly by clients.
        // NOTE: canonical doc uses English field name `category` (mapped from
        // legacy `categorie` in normalizeCanonicalExpenseClaimPayload).
        // Use .get(field, default) so a missing field doesn't deny the write.
        allow create: if isMember(clubId) && (
          canManageExpenses(clubId) ||
          (
            request.resource.data.requester_id == request.auth.uid
            && request.resource.data.get('category', '') != 'remboursement_inscription'
          )
        );

        // Update: User can update own claims (if not yet approved), admin+ can update all.
        // Status check uses canonical 'draft' / 'submitted' (mapped from legacy brouillon/soumis).
        allow update: if isMember(clubId)
          && hasCanonicalApprovalMetadata(request.resource.data)
          && (
            canManageExpenses(clubId) ||
            (
              getUserData(clubId).app_role == 'user' &&
              resource.data.requester_id == request.auth.uid &&
              resource.data.status in ['draft', 'submitted']
            )
          );

        // Delete: Admin only
        allow delete: if isAdmin(clubId)
          && hasValidSession(clubId)
          && canModifyFiscalYearData(clubId, resource.data.fiscal_year_id);
      }

      // Operations (événements, cotisations, dons, ventes, subventions)
      match /operations/{operationId} {
        // Read: Club members can read operations
        // (needed for event discussions, inscriptions, and operation details in mobile app)
        allow read: if isMember(clubId);

        // Create: app_role 'user' OR clubStatuten 'O' (Organisateur badge) can create their
        //   own events (type 'evenement'). Validateur+ can create any operation type.
        //   The Organisateur clause lets 'membre'-tier users (no CalyCompta admin access)
        //   still organize events when their clubStatuten includes the O-badge.
        // Note: uses .get() for fiscal_year_id to handle mobile app creating events without it
        allow create: if isAuthenticated()
          && hasValidSession(clubId)
          && request.resource.data.organisateur_id == request.auth.uid
          && (
            getUserData(clubId).app_role in ['superadmin', 'admin', 'validateur'] ||
            (getUserData(clubId).app_role == 'user' && request.resource.data.type == 'evenement') ||
            (isOrganisateurForClub(clubId) && request.resource.data.type == 'evenement')
          )
          && canModifyFiscalYearData(clubId, request.resource.data.get('fiscal_year_id', null));

        // Update: same access tiers as create — owner-only for non-admin tiers.
        // NOTE: .get('type', '') instead of bare access — legacy operations
        // could in theory be missing the `type` field, which would deny
        // owner-updates otherwise.
        allow update: if isAuthenticated()
          && hasValidSession(clubId)
          && (
            getUserData(clubId).app_role in ['superadmin', 'admin', 'validateur'] ||
            (
              getUserData(clubId).app_role == 'user' &&
              resource.data.organisateur_id == request.auth.uid &&
              request.resource.data.get('type', '') == 'evenement'
            ) ||
            (
              isOrganisateurForClub(clubId) &&
              resource.data.organisateur_id == request.auth.uid &&
              request.resource.data.get('type', '') == 'evenement'
            )
          )
          && canModifyFiscalYearData(clubId, request.resource.data.get('fiscal_year_id', null));

        // Delete: owner-only for non-admin tiers, admin+ can delete any.
        allow delete: if isAuthenticated()
          && hasValidSession(clubId)
          && (
            getUserData(clubId).app_role in ['superadmin', 'admin', 'validateur'] ||
            (getUserData(clubId).app_role == 'user' && resource.data.organisateur_id == request.auth.uid) ||
            (isOrganisateurForClub(clubId) && resource.data.organisateur_id == request.auth.uid)
          );

        // Inscriptions subcollection (web + mobile app)
        match /inscriptions/{inscriptionId} {
          allow read: if isMember(clubId);

          // Create: three legitimate paths
          //   1. Member registers themselves (membre_id == own uid).
          //      Blocked after the effective deadline — only admins via
          //      valid session can still register late.
          //   2. Admin with valid session registers anyone (incl. externals)
          //      — bypasses the deadline (admin override).
          //   3. Member adds a guest to THEIR OWN inscription from CalyMob,
          //      provided the event opted-in via allow_guests=true. Also
          //      blocked after the effective deadline.
          allow create: if isMember(clubId)
            && (
              (
                request.resource.data.membre_id == request.auth.uid
                && request.time <= effectiveDeadline(
                  get(/databases/$(database)/documents/clubs/$(clubId)/operations/$(operationId)).data
                )
              ) ||
              (hasValidSession(clubId) && isAdmin(clubId)) ||
              (
                // Use .get(field, default) on guest-only fields so the rule
                // matches the delete rule's style and doesn't trip the same
                // missing-field denial we hit on `categorie`.
                request.resource.data.get('is_guest', false) == true
                && request.resource.data.get('added_by', '') == request.auth.uid
                && request.resource.data.get('parent_inscription_id', null) != null
                && get(/databases/$(database)/documents/clubs/$(clubId)/operations/$(operationId))
                     .data.get('allow_guests', false) == true
                && get(/databases/$(database)/documents/clubs/$(clubId)/operations/$(operationId)/inscriptions/$(request.resource.data.parent_inscription_id))
                     .data.membre_id == request.auth.uid
                && request.time <= effectiveDeadline(
                  get(/databases/$(database)/documents/clubs/$(clubId)/operations/$(operationId)).data
                )
              )
            );

          // Delete: members unregister themselves OR delete their own guests
          // — both gated by the effective deadline so members can't bail
          // late and force a refund. Admins (any path) always pass.
          allow delete: if isMember(clubId)
            && (
              isAdmin(clubId)
              || (
                resource.data.membre_id == request.auth.uid
                && request.time <= effectiveDeadline(
                  get(/databases/$(database)/documents/clubs/$(clubId)/operations/$(operationId)).data
                )
              )
              || (
                resource.data.get('is_guest', false) == true
                && resource.data.get('added_by', '') == request.auth.uid
                && request.time <= effectiveDeadline(
                  get(/databases/$(database)/documents/clubs/$(clubId)/operations/$(operationId)).data
                )
              )
            );

          // Update: own inscription (mobile), session (web), or own guest.
          // Deadline check: members (not admins) cannot update after the effective deadline.
          // Admins with valid session bypass the deadline check.
          allow update: if isMember(clubId)
            && (
              request.auth.uid == resource.data.membre_id
              && request.time <= effectiveDeadline(
                get(/databases/$(database)/documents/clubs/$(clubId)/operations/$(operationId)).data
              )
              || hasValidSession(clubId)
              || (
                resource.data.get('is_guest', false) == true
                && resource.data.get('added_by', '') == request.auth.uid
                && request.time <= effectiveDeadline(
                  get(/databases/$(database)/documents/clubs/$(clubId)/operations/$(operationId)).data
                )
              )
            );

          // Edit history — append-only audit log van wijzigingen op een
          // inscription (supplements, gasten toegevoegd/verwijderd, ...).
          // Alleen de inscription-owner en admins met valid session mogen
          // lezen of schrijven. Geen update/delete: log is immutable.
          match /edit_history/{historyId} {
            allow read: if isMember(clubId) && (
              get(/databases/$(database)/documents/clubs/$(clubId)/operations/$(operationId)/inscriptions/$(inscriptionId)).data.membre_id == request.auth.uid
              || hasValidSession(clubId)
            );
            allow create: if isMember(clubId) && (
              get(/databases/$(database)/documents/clubs/$(clubId)/operations/$(operationId)/inscriptions/$(inscriptionId)).data.membre_id == request.auth.uid
              || hasValidSession(clubId)
            );
          }
        }

        // Palanquées subcollection (drag & drop palanquée assignments)
        match /palanquees/{docId} {
          // Read: Club members can see palanquée assignments
          allow read: if isMember(clubId);

          // Write: Admin OR Encadrant (E-badge) OR Organisateur (O-badge) with valid session.
          // Both roles can build/adjust palanquées during dive operations.
          allow create, update:
            if (isEncadrantForClub(clubId) || isOrganisateurForClub(clubId))
            && hasValidSession(clubId);

          // Delete: Admin OR Encadrant (E-badge) OR Organisateur (O-badge).
          allow delete: if isEncadrantForClub(clubId) || isOrganisateurForClub(clubId);
        }

        // Messages subcollection (event discussion - mobile app)
        match /messages/{messageId} {
          // Read: Club members can read messages
          allow read: if isMember(clubId);

          // Create: Club members can send messages (sender_id must match auth uid)
          allow create: if isMember(clubId)
            && request.resource.data.sender_id == request.auth.uid;

          // Delete: Author can delete own messages, admins can delete any
          allow delete: if isMember(clubId)
            && (resource.data.sender_id == request.auth.uid || isAdmin(clubId));

          // Update:
          //  - Alle members mogen read_by, reactions of poll updaten (bestaand gedrag voor reacties/polls).
          //  - De auteur mag zijn eigen bericht editen (message/attachments/edited_at).
          allow update: if isMember(clubId) && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read_by'])
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['poll'])
            || (
              resource.data.sender_id == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['message', 'attachments', 'edited_at'])
            )
          );
        }
      }

      // Operation participants (inscriptions, cotisations payées, etc.)
      match /operation_participants/{participantId} {
        allow read: if isMember(clubId);

        // Create: Club members can register themselves (mobile app - no session required)
        // OR an admin with a valid session creates the projection on behalf of
        // someone else — notably for guests (membre_id = guest_xxx), whose
        // projection can never match the admin's uid. Mirrors the update rule.
        allow create: if isMember(clubId)
          && (
            request.resource.data.membre_id == request.auth.uid
            || (isAdmin(clubId) && hasValidSession(clubId))
          );

        // Delete: Club members can unregister themselves (mobile app)
        allow delete: if isMember(clubId)
          && resource.data.membre_id == request.auth.uid;

        // Update: Requires session (web app) OR user owns the document (mobile app)
        allow update: if isMember(clubId)
          && (
            request.auth.uid == resource.data.membre_id
            || (
              hasValidSession(clubId)
              && (
                // Check fiscal year via parent operation
                !('operation_id' in request.resource.data) ||
                canModifyFiscalYearData(
                  clubId,
                  get(/databases/$(database)/documents/clubs/$(clubId)/operations/$(request.resource.data.operation_id)).data.fiscal_year_id
                )
              )
            )
          );
      }

      // LEGACY: Events - Gardé pour compatibilité migration
      match /events/{eventId} {
        allow read: if isMember(clubId);
        allow write: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // LEGACY: Event registrations - Gardé pour compatibilité migration
      match /event_registrations/{registrationId} {
        allow read: if isMember(clubId);
        allow write: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Inscriptions événements (pour stats dashboard)
      match /inscriptions_evenements/{inscriptionId} {
        allow read: if isMember(clubId);
        allow write: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Members - club membership required to read member list
      // During login: user reads own doc (isMember checks exists() which is true if doc exists)
      // Mobile app: member reads all members for member list
      // Web app: admin reads all members for user management
      match /members/{memberId} {
        allow read: if isMember(clubId) || (isAuthenticated() && request.auth.uid == memberId);

        // Allow users to update their own profile fields (needed during login/app usage, before session exists)
        // Includes: login timestamp, FCM tokens for push notifications, app installation tracking,
        // and unread_counts for badge management (decremented by the mobile app when reading messages)
        allow update: if isAuthenticated()
          && request.auth.uid == memberId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            // Login tracking
            'lastLogin', 'updatedAt',
            // Profile editing (CalyMob)
            'photo_url', 'photo_uploaded_at', 'updated_at',
            'consent_internal_photo', 'consent_internal_photo_date',
            'consent_external_photo', 'consent_external_photo_date',
            'share_email', 'share_phone', 'phone_number',
            'birth_date', 'date_naissance',
            'address_street', 'address_postcode', 'address_city', 'address_country',
            'adresse', 'code_postal', 'localite', 'pays',
            // Push notifications (CalyMob)
            'fcm_token', 'fcm_tokens', 'fcm_token_updated_at', 'notifications_enabled',
            // Notification preferences (CalyMob) - granular per-type toggle
            'notification_preferences',
            // App installation tracking (CalyMob)
            'app_installed', 'app_platform', 'app_version', 'app_build_number',
            'device_model', 'device_os_version', 'app_last_opened', 'app_first_installed',
            // Device telemetry (CalyMob notification_service)
            'device_brand', 'device_is_physical',
            // Diagnostics (CalyMob) - biometric status, error logs, health checks
            'diag_biometric', 'diag_errors', 'diag_last_error_at', 'diag_health',
            // Badge management (CalyMob) - unread message counters
            'unread_counts',
            // Medical certificate flag (CalyMob) - set when member uploads a new certificate
            'has_pending_medical',
            // Carnet de plongée — équipement personnel (CalyMob combi/tank pickers)
            'dive_combis', 'dive_tanks',
            // Web device info (CalyCompta) — fields written by saveDeviceInfoToMember
            'device_platform', 'device_type', 'browser_name', 'browser_version',
            'device_locale', 'device_timezone',
            'device_screen_width', 'device_screen_height', 'device_pixel_ratio',
            'web_last_login'
          ]);

        // Admins can create new members (for user management UI)
        allow create: if isAdmin(clubId) && hasValidSession(clubId);

        // Admins can update and delete members
        allow update, delete: if isAdmin(clubId) && hasValidSession(clubId);

        // Exercices validés par membre (suivi des formations LIFRAS)
        //
        // Workflow (per 2026-04-21):
        // - Le membre peut auto-déclarer un exercice via CalyMob ("Je l'ai fait"),
        //   status='pending' + declared_by_member=true.
        // - Un encadrant/admin valide ou refuse (status='validated'|'refused').
        // - Un encadrant/admin peut aussi créer directement un exercice déjà validé
        //   (workflow legacy : booking par moniteur dans CalyCompta).
        match /exercices_valides/{exerciceValideId} {
          // Lecture : le membre lui-même, admin/superadmin, ou encadrant
          // (encadrants doivent pouvoir voir la progression des membres qu'ils forment)
          allow read: if isAuthenticated() && (
            request.auth.uid == memberId ||
            isEncadrantForClub(clubId)
          );

          // Create :
          //  - Moniteur+Encadrant of admin : toute valeur de status (validation directe)
          //  - membre lui-même : uniquement self-declaration
          //    (status='pending' + declared_by_member=true)
          // Validatie is enkel voor Moniteurs (MC/MF/MN) — een Encadrant zonder
          // Moniteur-niveau kan dus enkel niet-validerende self-declarations zien.
          allow create: if canValidateLifras(clubId)
            || (
              isAuthenticated()
              && request.auth.uid == memberId
              && request.resource.data.status == 'pending'
              && request.resource.data.declared_by_member == true
            );

          // Update / delete : enkel Moniteur+Encadrant of admin (transitions
          // pending → validated / refused).
          allow update, delete: if canValidateLifras(clubId);
        }

        // WP-08 — historique de brevets (PP-H). La CF onPlongeurCodeChanged
        // écrit les 'plongeur_code_change' via l'Admin SDK (bypass rules). Le
        // membre peut ajouter ses propres dates d'homologation passées
        // (from='self_service') mais jamais modifier/supprimer ; admin corrige.
        match /brevet_history/{historyId} {
          allow read: if isAuthenticated() && (
            request.auth.uid == memberId ||
            isEncadrantForClub(clubId) ||
            isAdmin(clubId)
          );
          allow create: if isAdmin(clubId)
            || (
              isAuthenticated()
              && request.auth.uid == memberId
              && request.resource.data.from == 'self_service'
              && request.resource.data.recorded_by == request.auth.uid
            );
          allow update, delete: if isAdmin(clubId);
        }

        // WP-09 — snapshot de formation matérialisé. Document dérivé, écrit
        // UNIQUEMENT par les Cloud Functions (Admin SDK, bypass rules). Lecture :
        // le membre lui-même + tout encadrant (fiche 360° / Who's who — D14).
        // Jamais écrit côté client (le snapshot est un dérivé jetable).
        match /formation_snapshot/{snapshotId} {
          allow read: if isAuthenticated() && (
            request.auth.uid == memberId ||
            isEncadrantForClub(clubId) ||
            isAdmin(clubId)
          );
          allow write: if false;
        }

        // ========== MEDICAL CERTIFICATES (Certificats médicaux - CalyMob) ==========
        // Members upload their medical certificates, admins validate them
        match /medical_certificates/{certId} {
          // Read: Member can read their own certificates, admins can read all
          allow read: if isAuthenticated() && (
            request.auth.uid == memberId ||
            isAdmin(clubId)
          );

          // Create: Member can upload their own certificate (mobile app - no session required)
          allow create: if isAuthenticated()
            && request.auth.uid == memberId
            && request.resource.data.member_id == memberId
            && request.resource.data.status == 'pending';

          // Update: Admin only - for approving/rejecting certificates
          // Admins set valid_until date and status
          allow update: if isAdmin(clubId);

          // Delete: Admin only - for removing old/invalid certificates
          allow delete: if isAdmin(clubId);
        }

        // Sensitive self-service profile data (banking, emergency, medical).
        match /sensitive_info/{infoId} {
          allow read: if isAuthenticated() && (
            request.auth.uid == memberId ||
            isAdmin(clubId) ||
            (
              infoId == 'emergency' &&
              resource.data.gdpr_share_emergency_with_staff == true &&
              (isEncadrantForClub(clubId) || hasCARole(clubId))
            ) ||
            (
              infoId == 'medical' &&
              resource.data.gdpr_share_medical_with_staff == true &&
              (isEncadrantForClub(clubId) || hasCARole(clubId))
            )
          );

          allow create, update, delete: if isAuthenticated()
            && request.auth.uid == memberId
            && infoId in ['banking', 'emergency', 'medical'];
        }
      }

      // Fiscal years - club members can read (needed for reports page load)
      match /fiscal_years/{fiscalYearId} {
        allow read: if isMember(clubId);
        allow write: if isAdmin(clubId) && hasValidSession(clubId);

        // Bilan values subcollection - stores balance sheet values per fiscal year
        match /data/{dataId} {
          // Read: Admin/Validateur with valid session
          allow read: if isAuthenticated()
            && hasValidSession(clubId)
            && getUserData(clubId).app_role in ['superadmin', 'admin', 'validateur'];
          // Write: Admin with valid session
          allow create, update: if isAdmin(clubId) && hasValidSession(clubId);
          // Delete: Superadmin only
          allow delete: if isSuperAdmin(clubId) && hasValidSession(clubId);
        }
      }

      // Audit logs - admin can read, members can create
      match /audit_logs/{auditId} {
        allow read: if isAdmin(clubId) && hasValidSession(clubId);
        allow create: if isMember(clubId);
        allow update, delete: if false; // Audit logs are immutable
      }

      // ========== INVENTAIRE MODULE (ADMIN+ ACCESS - PHASE DÉVELOPPEMENT) ==========

      // Inventory configuration - nested structure (used by services)
      match /inventory_config/settings/{subcollection}/{docId} {
        // Read: tous les membres — CalyMob a besoin de item_types pour
        // résoudre les noms de matériel sur l'écran Prêts matériel.
        // Subcollections: item_types, checklists, caution_rules, locations, email_templates
        allow read: if isMember(clubId);
        allow write: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Item types - flat structure (used by test scripts, alternative to nested)
      match /item_types/{typeId} {
        // PHASE DÉVELOPPEMENT: Superadmin uniquement
        allow read, write: if isSuperAdmin(clubId) && hasValidSession(clubId);
      }

      // Checklists - flat structure (used by test scripts, alternative to nested)
      match /checklists/{checklistId} {
        // PHASE DÉVELOPPEMENT: Superadmin uniquement
        allow read, write: if isSuperAdmin(clubId) && hasValidSession(clubId);
      }

      // Inventory items (matériel unitaire)
      // Read: tous les membres (CalyMob — choix du matériel à emprunter).
      // Write: admin (gestion inventaire web + validation retour CalyMob qui
      // repasse l'item en 'disponible').
      match /inventory_items/{itemId} {
        allow read: if isMember(clubId);
        // Write requires fiscal year check if fiscal_year_id is present
        allow create, update: if isAdmin(clubId)
          && hasValidSession(clubId)
          && (!('fiscal_year_id' in request.resource.data) || canModifyFiscalYearData(clubId, request.resource.data.fiscal_year_id));
        allow delete: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // ⚠️ REMOVED: inventory_members collection (2025-10-31)
      // After unification, all members are now in /clubs/{clubId}/members
      // Collection inventory_members was empty and has been migrated

      // Inventory loans (prêts de matériel) - full name used by services
      // Read: tous les membres (écran Prêts matériel dans CalyMob).
      // Write: admin (le responsable valide les retours et déclenche le
      // remboursement de caution). Prêts gratuits → pas de fiscal_year_id.
      match /inventory_loans/{loanId} {
        allow read: if isMember(clubId);
        allow write: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Loans - simplified name (used by test scripts, alternative to inventory_loans)
      match /loans/{loanId} {
        allow read: if isMember(clubId);
        allow write: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Inventory loan requests (demandes de prêt envoyées depuis CalyMob)
      // Le membre crée et consulte SES PROPRES demandes ("Demander du
      // matériel"). L'admin gère tout : approbation → création du prêt
      // correspondant dans inventory_loans.
      match /inventory_loan_requests/{requestId} {
        allow read: if isMember(clubId)
          && (resource.data.memberId == request.auth.uid || isAdmin(clubId));
        allow create: if isMember(clubId)
          && request.resource.data.memberId == request.auth.uid
          && request.resource.data.status == 'submitted';
        allow update, delete: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // ========== INVENTORY AUDITS (Contrôle annuel) ==========
      // Audit d'inventaire annuel - permet de contrôler physiquement le matériel
      match /inventory_audits/{auditId} {
        // Admin+ can manage audits (annual inventory control)
        allow read, write: if isAdmin(clubId) && hasValidSession(clubId);

        // Sous-collection: items à contrôler dans cet audit
        match /items/{itemId} {
          allow read, write: if isAdmin(clubId) && hasValidSession(clubId);
        }
      }

      // ========== BOUTIQUE SNAPSHOTS (Clôtures stock boutique) ==========
      // Snapshots de la valeur stock boutique pour le Bilan comptable
      // Codes Bilan: 02.01.01 (Boutique Club) et 02.01.02 (Boutique LIFRAS)
      match /boutique_snapshots/{snapshotId} {
        // Admin+ can read and create/update snapshots
        allow read: if isAdmin(clubId) && hasValidSession(clubId);
        allow create, update: if isAdmin(clubId) && hasValidSession(clubId);
        // Delete: Superadmin only (verrouillée snapshots zijn belangrijk)
        allow delete: if isSuperAdmin(clubId) && hasValidSession(clubId);

        // Sous-collection: items in de snapshot
        match /items/{itemId} {
          allow read, write: if isAdmin(clubId) && hasValidSession(clubId);
        }
      }

      // ========== NODA PAYMENTS (OPEN BANKING) ==========
      // Noda payment records - admin access for payment management
      match /noda_payments/{paymentId} {
        // Read: Admin/Superadmin with valid session
        allow read: if isAdmin(clubId) && hasValidSession(clubId);
        // Create/Update: Admin/Superadmin with valid session
        allow create, update: if isAdmin(clubId) && hasValidSession(clubId);
        // Delete: Superadmin only
        allow delete: if isSuperAdmin(clubId) && hasValidSession(clubId);
      }

      // ========== MOLLIE PAYMENTS (BANCONTACT) ==========
      // Mollie payment records - admin access for payment testing/management
      match /mollie_payments/{paymentId} {
        // Read: Admin/Superadmin with valid session
        allow read: if isAdmin(clubId) && hasValidSession(clubId);
        // Create/Update: Admin/Superadmin with valid session
        allow create, update: if isAdmin(clubId) && hasValidSession(clubId);
        // Delete: Superadmin only
        allow delete: if isSuperAdmin(clubId) && hasValidSession(clubId);
      }

      // Mollie API logs - admin access for debugging
      match /mollie_logs/{logId} {
        // Read: Admin/Superadmin with valid session
        allow read: if isAdmin(clubId) && hasValidSession(clubId);
        // Create: Admin/Superadmin with valid session (logs are created by the demo page)
        allow create: if isAdmin(clubId) && hasValidSession(clubId);
        // Update/Delete: Not allowed (logs are immutable)
        allow update, delete: if false;
      }

      // ========== CLUB ANNOUNCEMENTS (Annonces du club) ==========
      // Club announcements - visible in mobile app, managed by admins
      // Collection name: 'announcements' (matches Flutter app)
      match /announcements/{announcementId} {
        // Read: All authenticated club members
        allow read: if isAuthenticated() &&
          exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid));
        // Create: Admin/Superadmin with valid session
        allow create: if isAdmin(clubId) && hasValidSession(clubId);
        // Update: Members can only update read_by and reply_count, admins can update all
        allow update: if isMember(clubId) && (
          isAdmin(clubId) ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read_by', 'reply_count'])
        );
        // Delete: Admin/Superadmin with valid session
        allow delete: if isAdmin(clubId) && hasValidSession(clubId);

        // Replies subcollection - members can reply to announcements
        match /replies/{replyId} {
          // Read: Club members
          allow read: if isMember(clubId);
          // Create: Club members can send replies (sender_id must match)
          allow create: if isMember(clubId) &&
            request.resource.data.sender_id == request.auth.uid;
          // Update:
          //  - Alle members mogen read_by updaten (bestaand gedrag).
          //  - De auteur mag zijn eigen reply editen (message/attachments/edited_at).
          allow update: if isMember(clubId) && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read_by'])
            || (
              resource.data.sender_id == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['message', 'attachments', 'edited_at'])
            )
          );
          // Delete: Author or admin
          allow delete: if isMember(clubId) &&
            (resource.data.sender_id == request.auth.uid || isAdmin(clubId));
        }
      }

      // ========== AVAILABILITIES (Beschikbaarheden voor piscine) ==========
      // Members can manage their own availability for pool sessions
      // Fields: membre_id, date, role ('accueil'|'encadrant'|'gonflage'), available (bool),
      //         time_slots (optional array: encadrant=['1ere_heure','2eme_heure'], gonflage=['19h45','20h15','21h30'])
      match /availabilities/{availabilityId} {
        // Read: All authenticated club members
        allow read: if isAuthenticated() &&
          exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid));
        // Create: Members can create their own availability
        // Validate: time_slots must be a list when present
        allow create: if isAuthenticated() &&
          exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)) &&
          request.resource.data.membre_id == request.auth.uid &&
          (!('time_slots' in request.resource.data) ||
           request.resource.data.time_slots == null ||
           request.resource.data.time_slots is list);
        // Update: Members can update their own availability
        // Validate: time_slots must be a list when present
        allow update: if isAuthenticated() &&
          exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)) &&
          resource.data.membre_id == request.auth.uid &&
          (!('time_slots' in request.resource.data) ||
           request.resource.data.time_slots == null ||
           request.resource.data.time_slots is list);
        // Delete: Members can delete their own availability
        allow delete: if isAuthenticated() &&
          exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)) &&
          resource.data.membre_id == request.auth.uid;
      }

      // ========== TEAM CHANNELS (Chat équipes: Accueil, Encadrants, Gonflage) ==========
      // Team channels - permanent chat for team coordination (mobile app)
      match /team_channels/{channelId} {
        // Read: only members with access to this channel.
        allow read: if canAccessTeamChannel(clubId, channelId);
        // Create: the app may initialize a channel, but the type must match the id.
        allow create: if canAccessTeamChannel(clubId, channelId)
          && teamChannelTypeMatches(channelId, request.resource.data.type);
        // Update metadata: admin only.
        allow update: if isAdmin(clubId);
        // Delete: Admin only
        allow delete: if isAdmin(clubId);

        // Messages subcollection - team chat messages
        match /messages/{messageId} {
          // Read: only members with access to this channel.
          allow read: if canAccessTeamChannel(clubId, channelId);
          // Create: Club members can send messages (sender_id must match)
          allow create: if canAccessTeamChannel(clubId, channelId) &&
            request.resource.data.sender_id == request.auth.uid;
          // Update:
          //  - Alle members mogen read_by, reactions of poll updaten.
          //  - De auteur mag zijn eigen bericht editen (message/attachments/edited_at).
          allow update: if canAccessTeamChannel(clubId, channelId) && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read_by'])
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['poll'])
            || (
              resource.data.sender_id == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['message', 'attachments', 'edited_at'])
            )
          );
          // Delete: Author or admin
          allow delete: if canAccessTeamChannel(clubId, channelId) &&
            (resource.data.sender_id == request.auth.uid || isAdmin(clubId));
        }
      }

      // ========== PISCINE SESSIONS (Pool training sessions) ==========
      // Piscine sessions - managed by admins, visible to members
      // Fields: date, statut, lieu, horaire, niveaux (map), accueil (array), baptemes (array),
      //         gonflage (map: {19h45, 20h15, 21h30} → array), type ('piscine'|'theorie'),
      //         theorie (optional map: {19h30, 21h45} → {encadrants, theme})
      match /piscine_sessions/{sessionId} {
        // Read: All authenticated club members (mobile app - no session required)
        allow read: if isAuthenticated() &&
          exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid));
        // Write: Admin OR Piscine-editor (E or P badge) with valid session for web.
        // Validate: type must be 'piscine' or 'theorie' when present.
        allow create, update: if isPiscineFormationEditor(clubId) &&
          (!('type' in request.resource.data) || request.resource.data.type in ['piscine', 'theorie']);
        allow delete: if isPiscineFormationEditor(clubId);

        // Attendees subcollection - scanner adds attendees here
        match /attendees/{attendeeId} {
          // Read: All authenticated club members
          allow read: if isMember(clubId) || isAdmin(clubId);
          // Create: Any authenticated club member can scan (mobile app scanner)
          allow create: if isMember(clubId)
            && request.resource.data.scannedAt is timestamp
            && request.resource.data.scannedBy is string
            && request.resource.data.scannedBy.size() > 0
            && request.resource.data.memberName is string
            && request.resource.data.memberName.size() > 0
            && (
              (request.resource.data.memberId is string
                && request.resource.data.memberId.size() > 0)
              || request.resource.data.isGuest == true
            );
          // Delete: Admin only (to remove wrongly scanned attendees)
          allow delete: if isAdmin(clubId);
          // Update: niveau-toewijzing en pedagogische remarks per attendee zijn
          // pedagogische beslissingen — enkel Moniteur+Encadrant of admin.
          // Velden buiten deze whitelist (memberId, memberName, scannedAt,
          // scannedBy, isGuest, ...) blijven immutable.
          allow update: if canValidateLifras(clubId) &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['assignedLevel', 'assignedCourseId', 'assignedToMemberId', 'remarks', 'sentToReserve']);
        }

        // Messages subcollection - discussion for piscine sessions (mobile app)
        match /messages/{messageId} {
          // Read: Club members
          allow read: if isMember(clubId);
          // Create: Club members can send messages (sender_id must match)
          allow create: if isMember(clubId) &&
            request.resource.data.sender_id == request.auth.uid;
          // Update:
          //  - Alle members mogen read_by, reactions of poll updaten.
          //  - De auteur mag zijn eigen bericht editen (message/attachments/edited_at).
          allow update: if isMember(clubId) && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read_by'])
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['poll'])
            || (
              resource.data.sender_id == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['message', 'attachments', 'edited_at'])
            )
          );
          // Delete: Author or admin
          allow delete: if isMember(clubId) &&
            (resource.data.sender_id == request.auth.uid || isAdmin(clubId));
        }
      }

      // ========== ATTENDANCE (Aanwezigheidsregistratie - CalyMob) ==========
      // Attendance records - used by CalyMob for tracking member attendance
      match /attendance/{attendanceId} {
        // Read: All club members can view attendance
        allow read: if isMember(clubId);
        // Create: Members can record attendance (mobile app scanner) —
        //   includes admins, encadrants, and regular members marking themselves/others.
        allow create: if isMember(clubId);
        // Update / Delete: Admin OR Encadrant (E-badge) OR Organisateur (O-badge).
        //   Encadrants and organisateurs both need to toggle presence on the event
        //   detail view (mark present/absent), so the delete path is just as important
        //   as create.
        allow update, delete:
          if isAdmin(clubId) || isEncadrantForClub(clubId) || isOrganisateurForClub(clubId);
      }

      // ========== BOUTIQUE STOCK (Stockbeheer voor boutique) ==========
      // Boutique stock management - used for Bilan codes 02.01.01 (Boutique) and 02.01.02 (Boutique LIFRAS)
      match /boutique_stock/{itemId} {
        // Read: Admin/Validateur with valid session
        allow read: if isAuthenticated()
          && hasValidSession(clubId)
          && getUserData(clubId).app_role in ['superadmin', 'admin', 'validateur'];
        // Create/Update: Admin with valid session
        allow create, update: if isAdmin(clubId) && hasValidSession(clubId);
        // Delete: Superadmin only
        allow delete: if isSuperAdmin(clubId) && hasValidSession(clubId);
      }

      // ========== FOURNISSEURS (Leveranciers voor terugbetalingen) ==========
      // Fournisseurs - used for expense reimbursements to third parties (non-members)
      match /fournisseurs/{fournisseurId} {
        // Read/Create/Update: expense managers need suppliers in the expense workflow.
        allow read: if isMember(clubId) && canManageExpenses(clubId);
        allow create, update: if canManageExpenses(clubId) && hasValidSession(clubId);
        // Delete: Superadmin only (soft delete via 'actif' field is preferred)
        allow delete: if isSuperAdmin(clubId) && hasValidSession(clubId);
      }

      // ========== SMS MODULE (Twilio Integration) ==========
      // SMS history - track sent SMS messages
      match /sms_history/{historyId} {
        // Read: Admin/Superadmin with valid session
        allow read: if isAdmin(clubId) && hasValidSession(clubId);
        // Create: Admin with valid session (Vercel API uses Admin SDK which bypasses rules)
        allow create: if isAdmin(clubId) && hasValidSession(clubId);
        // Update/Delete: Admin only (for marking delivered status updates)
        allow update, delete: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // SMS logs - execution logs for scheduled SMS jobs
      match /sms_logs/{logId} {
        // Read: Admin/Superadmin with valid session
        allow read: if isAdmin(clubId) && hasValidSession(clubId);
        // Create: Only Cloud Functions/Vercel API can create logs
        allow create: if false;
        // Update/Delete: Logs are immutable
        allow update, delete: if false;
      }

      // SMS templates - reusable message templates
      match /sms_templates/{templateId} {
        // Read: Admin/Superadmin with valid session
        allow read: if isAdmin(clubId) && hasValidSession(clubId);
        // Write: Admin/Superadmin with valid session
        allow create, update, delete: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Member SMS preferences subcollection
      // Note: This is a subcollection under /members/{memberId}/preferences/sms
      // Rules are inherited from the members match block above

      // ========== MEMBERSHIP SEASONS (COTISATIONS) ==========

      // Boutique catalogue products — CalyMob reads published products directly.
      match /products/{productId} {
        allow read: if isAdmin(clubId) || (
          canAccessBoutique(clubId) &&
          resource.data.visibility == 'published'
        );
        allow create, update, delete: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // Membership tariff seasons — cotisations par saison
      match /membership_seasons/{seasonId} {
        // Read: all members, including CalyMob where no CalyCompta session exists.
        allow read: if isMember(clubId);
        // Write: admin only
        allow create, update, delete: if isAdmin(clubId) && hasValidSession(clubId);
      }

      // ========== BUG REPORTING MODULE ==========

      // Bug reports — signalements de bugs par les utilisateurs
      match /bug_reports/{reportId} {
        // Lecture: admin uniquement (pour voir tous les signalements)
        allow read: if isAdmin(clubId) && hasValidSession(clubId);
        // Création: tout membre authentifié peut signaler un bug
        // Guard 'reporter' presence before chained access — a missing
        // `reporter` map would throw and deny the write otherwise.
        allow create: if isMember(clubId)
          && 'reporter' in request.resource.data
          && request.resource.data.reporter.uid == request.auth.uid;
        // Modification: admin uniquement (pour mettre à jour le statut, linearIssueId)
        allow update: if isAdmin(clubId) && hasValidSession(clubId);
        // Suppression: admin uniquement
        allow delete: if isAdmin(clubId) && hasValidSession(clubId);

        // Commentaires sur les bug reports
        match /comments/{commentId} {
          allow read: if isAdmin(clubId) && hasValidSession(clubId);
          allow create: if isAdmin(clubId) && hasValidSession(clubId);
          allow delete: if isAdmin(clubId) && hasValidSession(clubId);
        }
      }
    }

    // User profiles (global, not club-specific)
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false; // Never allow deletion
    }

    // Global settings (not club-specific) - used for app version control
    match /settings/{settingId} {
      // app_version: All authenticated users can read (for version check on app load)
      allow read: if isAuthenticated() && settingId == 'app_version';
      // Write: Only admins from any club can update (typically superadmin)
      // For now, only allow authenticated users with admin claim in their token
      allow write: if isAuthenticated() && request.auth.token.app_role in ['admin', 'superadmin'];
    }

    // Value Lists - Waardelijsten
    match /clubs/{clubId}/value_lists/{listId} {
      // Read: club members with valid session
      allow read: if isMember(clubId) && hasValidSession(clubId);

      // Create: admin/validateur only, club lists only (prevent creating system lists)
      allow create: if isAuthenticated()
        && hasValidSession(clubId)
        && (isAdmin(clubId) || getUserData(clubId).app_role == 'validateur')
        && request.resource.data.type == 'club';

      // Update/Delete: admin/validateur only, club lists only (system lists read-only)
      allow update, delete: if isAuthenticated()
        && hasValidSession(clubId)
        && (isAdmin(clubId) || getUserData(clubId).app_role == 'validateur')
        && resource.data.type == 'club';
    }

    // ========== CARNET DE FORMATION — Session Themes ==========
    // Pedagogische thema-catalogus — alleen Moniteur+Encadrant of admin.
    // P-badge alleen volstaat niet meer (P is operationeel zwembad-management,
    // niet pedagogisch).
    match /clubs/{clubId}/session_themes/{themeId} {
      // Lecture: tous les membres authentifiés
      allow read: if isAuthenticated() &&
        exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid));
      allow create, update, delete: if canValidateLifras(clubId);
    }

    // ========== CARNET DE FORMATION — Member Observations ==========
    // Pedagogische observaties op leden — alleen Moniteur+Encadrant of admin.
    // Vóór 2026-04-29 stond hier enkel een observerId-check, wat elke
    // geauthenticeerde clublid liet schrijven via direct API-call. Nu strikt
    // afgestemd op de CARNET_DE_FORMATION_TECH.md intent ("encadrants et admins")
    // én op de LIFRAS-realiteit (alleen Moniteurs valideren).
    match /clubs/{clubId}/member_observations/{observationId} {
      // Lecture: tous les membres authentifiés
      allow read: if isAuthenticated() &&
        exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid));
      // Création: Moniteur+Encadrant of admin, en moet zelf de observer zijn
      allow create: if canValidateLifras(clubId) &&
        request.resource.data.observerId == request.auth.uid;
      // Modification: oorspronkelijke auteur (mits nog steeds Moniteur+Encadrant), of admin
      allow update: if isAdmin(clubId) || (
        canValidateLifras(clubId) &&
        resource.data.observerId == request.auth.uid
      );
      // Suppression: admin uniquement
      allow delete: if isAdmin(clubId);
    }

    // ===== Collection-group read for operation inscriptions =====
    // Used by CalyMob's OperationService.getUserRegistrationsStream() and
    // MessagesScreen._loadUserEvents() to query across all
    // operations/*/inscriptions subcollections in one go.
    // Path when matched: clubs/{clubId}/operations/{opId}/inscriptions/{inscId}
    //
    // Same single-tenant pattern as the attendees CG rule below:
    // hardcode clubs/calypso so the rule is evaluable at query-authorization
    // time (path[...] indexing doesn't work for CG queries).
    match /{path=**}/inscriptions/{inscriptionId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/clubs/calypso/members/$(request.auth.uid));
    }

    // ===== Collection-group read for piscine attendees =====
    // Used by formation/progression ("Présences cette saison") to query
    // across all piscine_sessions/*/attendees subcollections in one go.
    // Path when matched: clubs/{clubId}/piscine_sessions/{sid}/attendees/{aid}
    //
    // IMPORTANT: for collection-GROUP queries Firestore evaluates rules at
    // query-authorization time BEFORE fetching any docs, so `path[...]`
    // indexing and `exists(/databases/.../clubs/$(path[1])/members/...)`
    // cannot be resolved and the query is denied (permission-denied). This
    // is why the earlier path[1]-based rule silently broke "Présences cette
    // saison" — the CG query returned 0 docs via attendanceService's
    // silent `.catch()` fallback, even though every single attendee doc
    // existed and was readable one-by-one.
    //
    // Fix: use a field-based / hardcoded-club check that doesn't depend on
    // the wildcard path. Calypso is single-tenant (clubs/calypso) so the
    // check is equivalent and equally secure. The nested rule under
    // /clubs/{clubId}/piscine_sessions/{sid}/attendees still handles direct
    // reads/writes and creation within a single session.
    match /{path=**}/attendees/{attendeeId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/clubs/calypso/members/$(request.auth.uid));
    }

    // ========================================================================
    // CARNET DE FORMATION (Training Logbook) — phase 1
    //
    // Three new collections introduced by the Carnet de Formation feature.
    // See `CARNET_DE_FORMATION_TECH.md` §10 for the spec. Cloud Functions
    // running with the Admin SDK BYPASS these rules (that's how task
    // creation is done programmatically); the rules below govern what
    // clients are allowed to read/write.
    // ========================================================================

    // --- historical_exercise_claim_batches --------------------------------
    // Mobile "Reprendre ma carte papier" flow. A member submits the exercises
    // already signed on paper; a LIFRAS monitor validates them in person.
    match /clubs/{clubId}/historical_exercise_claim_batches/{batchId} {
      allow read: if isMember(clubId) && (
           resource.data.member_id == request.auth.uid
        || canValidateLifras(clubId)
      );

      allow create: if isMember(clubId)
        && request.resource.data.member_id == request.auth.uid
        && request.resource.data.submitted_by == request.auth.uid
        && request.resource.data.status == 'submitted'
        && request.resource.data.source == 'student_historical_claim'
        && request.resource.data.evidence_required == 'paper_progress_card';

      allow update: if canValidateLifras(clubId);
      allow delete: if isAdmin(clubId);
    }

    // --- formation_tasks ---------------------------------------------------
    // The persistent inbox. Clients can READ their own tasks and tasks where
    // they're the current assignee; admins/encadrants can read all.
    // Clients CANNOT create tasks directly — only Cloud Functions do that
    // via the Admin SDK (which bypasses rules anyway), except for the
    // student-facing "historical_validation" task created atomically by the
    // mobile paper-card reprise flow.
    // Clients can UPDATE only a narrow set of fields on tasks where they're
    // the current assignee (status transitions + snooze + completion stamps).
    match /clubs/{clubId}/formation_tasks/{taskId} {
      allow read: if isMember(clubId) && (
           resource.data.member_id == request.auth.uid
        || resource.data.current_assignee_id == request.auth.uid
        || isAdmin(clubId)
        || isEncadrantForClub(clubId)
      );

      // Clients never create directly — Cloud Functions only (Admin SDK).
      // Admins/encadrants may create manual_reminder tasks via the cockpit.
      // Mobile members may create their own historical_validation task so the
      // pending reprise remains visible in their inbox/QR flow.
      allow create: if isAdmin(clubId)
        || isEncadrantForClub(clubId)
        || (
          isMember(clubId)
          && request.resource.data.type == 'historical_validation'
          && request.resource.data.status == 'waiting_for_other'
          && request.resource.data.member_id == request.auth.uid
          && request.resource.data.current_assignee_id == request.auth.uid
          && request.resource.data.current_assignee_type == 'student'
          && request.resource.data.created_by == request.auth.uid
        );

      allow update: if isMember(clubId) && (
           resource.data.current_assignee_id == request.auth.uid
        || isAdmin(clubId)
        || isEncadrantForClub(clubId)
      ) && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'status',
              'snoozed_until',
              'completed_at',
              'completed_by',
              'completion_data',
              'notification_state',
              'updated_at',
            ]);

      allow delete: if isAdmin(clubId);
    }

    // --- exercise_claims ---------------------------------------------------
    // Student declares; assigned monitor (or encadrant/admin) decides.
    // Student can create their own claim and edit it while draft/submitted.
    // The assigned monitor can update the claim once it routes to them.
    // The official record (member_observations) is written by Cloud Function
    // onClaimAccepted — never directly by the client.
    match /clubs/{clubId}/exercise_claims/{claimId} {
      allow read: if isMember(clubId) && (
           resource.data.member_id == request.auth.uid
        || resource.data.monitor_id == request.auth.uid
        || isAdmin(clubId)
        || isEncadrantForClub(clubId)
      );

      allow create: if isMember(clubId)
        && request.resource.data.member_id == request.auth.uid
        && request.resource.data.declared_by == request.auth.uid;

      // WP-02 — la raison de refus (decision.*) n'est modifiable que par le
      // validateur assigné (monitor_id) ou un admin/encadrant. L'élève ne peut
      // que : éditer son claim tant qu'il est draft/submitted, OU faire une des
      // deux transitions autorisées après un refus (re-soumettre / abandonner),
      // sans toucher à la décision du moniteur.
      allow update: if isMember(clubId) && (
           (resource.data.member_id == request.auth.uid
            && resource.data.status in ['draft', 'submitted'])
        // Re-soumission : rejected → submitted, retry_count +1 exact, decision inchangée.
        || (resource.data.member_id == request.auth.uid
            && resource.data.status == 'rejected'
            && request.resource.data.status == 'submitted'
            && request.resource.data.retry_count ==
                 (resource.data.retry_count is int ? resource.data.retry_count : 0) + 1
            && request.resource.data.decision == resource.data.decision)
        // Abandon : rejected → abandoned, decision inchangée.
        || (resource.data.member_id == request.auth.uid
            && resource.data.status == 'rejected'
            && request.resource.data.status == 'abandoned'
            && request.resource.data.decision == resource.data.decision)
        || resource.data.monitor_id == request.auth.uid
        || isAdmin(clubId)
        || isEncadrantForClub(clubId)
      );

      allow delete: if isAdmin(clubId);
    }

    // --- student_logbook_entries -------------------------------------------
    // Personal dive log. Member owns their entries. Admins/encadrants can
    // read for support purposes; buddies do NOT have implicit read access
    // (a future buddy_confirmation flow grants per-entry read on request).
    match /clubs/{clubId}/student_logbook_entries/{entryId} {
      allow read: if isMember(clubId) && (
           resource.data.member_id == request.auth.uid
        || isAdmin(clubId)
        || isEncadrantForClub(clubId)
      );

      allow create: if isMember(clubId)
        && request.resource.data.member_id == request.auth.uid;

      allow update, delete: if isMember(clubId)
        && resource.data.member_id == request.auth.uid;
    }

    // --- logbook_dive_confirmations ------------------------------------------
    // Demandes de confirmation de plongée entre binômes. Tous les writes
    // passent exclusivement par les Cloud Functions (Admin SDK):
    // sendLogbookDiveConfirmations / respondToLogbookDiveConfirmation.
    // Les clients lisent uniquement: le destinataire voit ses demandes,
    // l'expéditeur suit le statut de ce qu'il a envoyé.
    // NB: les queries clients DOIVENT filtrer sur target_member_id ou
    // source_member_id == uid, sinon la rule n'est pas prouvable (deny).
    match /clubs/{clubId}/logbook_dive_confirmations/{confirmationId} {
      allow read: if isMember(clubId) && (
           resource.data.target_member_id == request.auth.uid
        || resource.data.source_member_id == request.auth.uid
        || isAdmin(clubId)
      );
      allow write: if false; // Cloud Functions uniquement
    }

    // --- member_observations write-protection note --------------------------
    // The existing `member_observations` collection rules live elsewhere
    // in this file (see canValidateLifras-gated section). With the Carnet
    // de Formation feature the writes MUST flow exclusively through the
    // Cloud Function `onClaimAccepted` (Admin SDK, bypasses these rules).
    // Phase 2 will tighten the existing client-side write rule to disallow
    // direct member_observations creates from the web admin (encadrants
    // will then have to go through the claim → accept flow). Until phase 2
    // ships the current write rule stays as-is to avoid breaking the
    // CalyCompta exercise-validation UI.

    // --- phase 6 note (member self-service web view) ------------------------
    // Phase 6 introduces /me/* member-tier routes. The rules above are
    // already member-scoped via `member_id == request.auth.uid`, so member
    // tokens calling the web client behave identically to mobile clients.
    // No rule changes are required for phase 6 — only a client-side
    // router guard to block member-tier tokens from admin routes.

    // ========================================================================
    // BOUTIQUE — web preparation surface
    //
    // Admins can prepare the product catalogue, inspect orders and configure
    // accounting/stock plumbing from CalyCompta. Member-facing order creation
    // will later move through Cloud Functions; direct client writes stay tight.
    // ========================================================================

    match /clubs/{clubId}/products/{productId} {
      allow read: if (isAdmin(clubId) && hasValidSession(clubId)) || (
        isMember(clubId) && hasValidSession(clubId) && resource.data.visibility == 'published'
      );
      allow create, update, delete: if isAdmin(clubId) && hasValidSession(clubId);
    }

    match /clubs/{clubId}/orders/{orderId} {
      allow read: if (isAdmin(clubId) && hasValidSession(clubId)) || (
        isMember(clubId) && hasValidSession(clubId) && resource.data.buyer.userId == request.auth.uid
      );
      allow create: if isMember(clubId)
        && hasValidSession(clubId)
        && request.resource.data.buyer.userId == request.auth.uid;
      allow update, delete: if isAdmin(clubId) && hasValidSession(clubId);
    }

    match /clubs/{clubId}/supplier_order_batches/{batchId} {
      allow read, write: if isAdmin(clubId) && hasValidSession(clubId);
    }

    match /clubs/{clubId}/delivery_notes/{noteId} {
      allow read, write: if isAdmin(clubId) && hasValidSession(clubId);
    }

    match /clubs/{clubId}/cotisation_payments/{paymentId} {
      allow read: if (isAdmin(clubId) && hasValidSession(clubId)) || (
        isMember(clubId) && hasValidSession(clubId) && resource.data.memberId == request.auth.uid
      );
      allow write: if isAdmin(clubId) && hasValidSession(clubId);
    }

    match /clubs/{clubId}/inventoryMutations/{mutationId} {
      allow read, write: if isAdmin(clubId) && hasValidSession(clubId);
    }

    match /clubs/{clubId}/settings/contextAccountMapping {
      allow read: if isMember(clubId);
      allow write: if isAdmin(clubId);
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }

    // Top-level inbound email provider audit.
    // Writes are performed by trusted server routes only.
    match /email_inbound_events/{eventId} {
      allow read: if hasValidAdminSessionForClubId(resource.data.club_id);
      allow create, update, delete: if false;
    }
  }
}
